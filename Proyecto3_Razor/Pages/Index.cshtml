@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">Sistema de Control Bancario</h1>
    <p class="lead">Bienvenido al panel de administración del Proyecto 3 - IPC2.</p>

    <div class="card shadow-sm mx-auto mt-5 border-danger" style="max-width: 500px;">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Zona de Peligro</h5>
        </div>
        <div class="card-body">
            <p class="card-text text-muted">
                Esta acción eliminará todos los clientes, bancos, facturas y pagos del sistema, tanto en memoria como en los archivos físicos. Úselo para iniciar pruebas desde cero.
            </p>
            <form method="post">
                <button type="submit" class="btn btn-outline-danger w-100 fw-bold">
                    <i class="bi bi-trash3-fill"></i> Limpiar Todos los Datos
                </button>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.MensajeRespuesta))
    {
        <div class="alert alert-info mt-4 mx-auto text-break text-start shadow-sm" style="max-width: 500px;">
            <h5 class="alert-heading"><i class="bi bi-info-circle-fill"></i> Respuesta del Servidor:</h5>
            <hr>
            <pre class="mb-0">@Model.MensajeRespuesta</pre>
        </div>
    }
</div>