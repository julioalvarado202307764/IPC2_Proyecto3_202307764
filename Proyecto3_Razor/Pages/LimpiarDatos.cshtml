@page
@model Proyecto3_Razor.Pages.LimpiarDatosModel
@{
    ViewData["Title"] = "Limpiar Sistema";
}

<div class="container mt-5">
    <div class="card shadow-sm mx-auto border-danger" style="max-width: 600px;">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Zona de Peligro: Reinicio del Sistema</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>¡Advertencia!</strong> Esta acción es irreversible. Eliminará todos los clientes, bancos, facturas y pagos del sistema, tanto en memoria como en los archivos físicos XML.
            </div>
            <p class="card-text text-muted">
                Úselo únicamente si necesita iniciar un nuevo ciclo de pruebas desde cero.
            </p>
            <form method="post">
                <button type="submit" class="btn btn-outline-danger w-100 fw-bold btn-lg">
                    <i class="bi bi-trash3-fill"></i> Confirmar y Limpiar Todos los Datos
                </button>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.MensajeRespuesta))
    {
        <div class="alert alert-info mt-4 mx-auto text-break text-start shadow-sm" style="max-width: 600px;">
            <h5 class="alert-heading"><i class="bi bi-info-circle-fill"></i> Respuesta del Servidor:</h5>
            <hr>
            <pre class="mb-0">@Model.MensajeRespuesta</pre>
        </div>
    }
</div>