@page
@model Proyecto3_Razor.Pages.ResumenPagosModel
@{
    ViewData["Title"] = "Resumen de Pagos";
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0"><i class="bi bi-bar-chart-fill"></i> Ingresos por Banco</h4>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 mb-4 justify-content-center">
                <div class="col-md-3">
                    <label class="form-label">Mes (1-12):</label>
                    <input type="number" name="Mes" class="form-control" min="1" max="12" value="@Model.Mes" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Año:</label>
                    <input type="number" name="Anio" class="form-control" min="2000" value="@(Model.Anio ?? DateTime.Now.Year)" required>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Generar Gráfica</button>
                </div>
            </form>

            <hr />

            @if (!string.IsNullOrEmpty(Model.MensajeError))
            {
                <div class="alert alert-danger">@Model.MensajeError</div>
            }
            else if (Model.ResumenDatos != null && Model.ResumenDatos.Bancos.Any())
            {
                <div class="text-end mb-3">
                    <button onclick="exportarGraficaPDF()" class="btn btn-danger shadow-sm fw-bold">
                        <i class="bi bi-file-earmark-pdf-fill"></i> Descargar Gráfica en PDF
                    </button>
                </div>

                <div id="grafica-pdf" class="p-4 bg-white rounded">
                    
                    <div class="text-center mb-4">
                        <h3 class="fw-bold">Reporte de Ingresos por Banco</h3>
                        <p class="mb-0 text-muted">Período analizado: @Model.ResumenDatos.Fechas.Mes1 a @Model.ResumenDatos.Fechas.Mes3</p>
                        <p class="mb-0 text-muted">Fecha de emisión: @DateTime.Now.ToString("dd/MM/yyyy")</p>
                    </div>

                    <div style="height: 400px; width: 100%;">
                        <canvas id="graficaBancos"></canvas>
                    </div>
                </div>

                <script>
                    // Configuración de Chart.js
                    const etiquetasFechas = [
                        '@Model.ResumenDatos.Fechas.Mes1', 
                        '@Model.ResumenDatos.Fechas.Mes2', 
                        '@Model.ResumenDatos.Fechas.Mes3'
                    ];
                    
                    const datosBancos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ResumenDatos.Bancos));
                    const colores = ['#0d6efd', '#fd7e14', '#198754', '#dc3545', '#6c757d'];
                    
                    const datasetsGrafica = datosBancos.map((banco, index) => {
                        return {
                            label: banco.Nombre,
                            data: [banco.TotalMes1, banco.TotalMes2, banco.TotalMes3],
                            backgroundColor: colores[index % colores.length],
                            borderWidth: 1
                        };
                    });

                    const ctx = document.getElementById('graficaBancos').getContext('2d');
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: etiquetasFechas,
                            datasets: datasetsGrafica
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    title: {
                                        display: true,
                                        text: 'Miles de Quetzales'
                                    }
                                }
                            },
                            plugins: {
                                title: {
                                    display: true,
                                    text: 'Ingresos por banco (De ' + etiquetasFechas[0] + ' a ' + etiquetasFechas[2] + ')',
                                    font: { size: 16 }
                                }
                            }
                        }
                    });

                    // 4. Script para generar el PDF de la gráfica
                    function exportarGraficaPDF() {
                        const elemento = document.getElementById('grafica-pdf');
                        
                        const opciones = {
                            margin:       0.5,
                            filename:     'IngresosBancos_M@(Model.Mes)_A@(Model.Anio).pdf',
                            image:        { type: 'jpeg', quality: 0.98 },
                            // Forzamos el fondo blanco para que la gráfica no salga transparente
                            html2canvas:  { scale: 2, backgroundColor: '#ffffff' }, 
                            // Landscape (horizontal) para que la gráfica tenga mejor proporción
                            jsPDF:        { unit: 'in', format: 'letter', orientation: 'landscape' }
                        };

                        html2pdf().set(opciones).from(elemento).save();
                    }
                </script>
            }
            else if (Model.Mes.HasValue)
            {
                 <div class="alert alert-warning text-center">No hay datos registrados para mostrar en este rango de fechas.</div>
            }
        </div>
    </div>
</div>