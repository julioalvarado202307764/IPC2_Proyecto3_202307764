<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proyecto3_Razor</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Proyecto3_Razor.styles.css" asp-append-version="true" />
</head>

<body>
    <div class="container mt-4">
        <main role="main" class="pb-3">
            
            @if (ViewContext.RouteData.Values["page"]?.ToString() != "/Index")
            {
                <div class="mb-4">
                    <a asp-page="/Index" class="btn btn-outline-dark fw-bold shadow-sm rounded-pill px-4">
                        <i class="bi bi-arrow-left"></i> Volver al Menú Principal
                    </a>
                </div>
            }

            @RenderBody()
            
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - Sistema de Control Bancario - IPC2 (Julio Alvarado)
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>