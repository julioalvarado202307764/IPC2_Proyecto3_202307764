@page
@model Proyecto3_Razor.Pages.EstadoCuentaModel
@{
    ViewData["Title"] = "Estado de Cuenta";
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Consulta de Estado de Cuenta</h4>
            <span class="badge bg-info">IPC2 - Proyecto 3</span>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 mb-4">
                <div class="col-md-8">
                    <input type="text" name="nit" class="form-control" placeholder="Ingrese NIT del cliente (ej. 202307764)" value="@Request.Query["nit"]">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">Consultar</button>
                </div>
            </form>

            <hr />

            @if (Model.Clientes != null && Model.Clientes.Any())
            {
                <div class="text-end mb-3">
                    <button onclick="exportarPDF()" class="btn btn-danger shadow-sm fw-bold">
                        <i class="bi bi-file-earmark-pdf-fill"></i> Descargar Reporte en PDF
                    </button>
                </div>

                <div id="reporte-pdf" class="p-4 bg-white rounded">
                    
                    <div class="text-center mb-4">
                        <h3 class="fw-bold">Estado de Cuenta Oficial</h3>
                        <p class="mb-0 text-muted">Fecha de emisión: @DateTime.Now.ToString("dd/MM/yyyy")</p>
                    </div>

                    @foreach (var cliente in Model.Clientes)
                    {
                        <div class="mb-5">
                            <div class="row alert alert-info mx-0 border border-info">
                                <div class="col-md-6">
                                    <h5 class="mb-0"><strong>Cliente:</strong> @cliente.Nombre (@cliente.NIT)</h5>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <h5 class="mb-0 @(cliente.SaldoActual < 0 ? "text-success" : "text-danger")">
                                        <strong>Saldo Actual:</strong> Q @Math.Abs(cliente.SaldoActual).ToString("N2")
                                        @(cliente.SaldoActual < 0 ? "(A Favor)" : "")
                                    </h5>
                                </div>
                            </div>

                            <table class="table table-striped table-hover mt-3 border">
                                <thead class="table-secondary">
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Cargo (Deuda)</th>
                                        <th>Abono (Pago)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var trans in cliente.Transacciones)
                                    {
                                        <tr>
                                            <td>@trans.Fecha</td>
                                            <td class="text-danger">@trans.Cargo</td>
                                            <td class="text-success">@trans.Abono</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <script>
                    function exportarPDF() {
                        const elemento = document.getElementById('reporte-pdf');
                        
                        // Determinamos el nombre del archivo basado en si buscó un NIT o si son todos
                        let nitBuscado = '@Request.Query["nit"]';
                        let nombreArchivo = nitBuscado ? 'EstadoDeCuenta_' + nitBuscado + '.pdf' : 'EstadoDeCuenta_General.pdf';

                        const opciones = {
                            margin:       0.5,
                            filename:     nombreArchivo,
                            image:        { type: 'jpeg', quality: 0.98 },
                            html2canvas:  { scale: 2 },
                            jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
                        };

                        html2pdf().set(opciones).from(elemento).save();
                    }
                </script>
            }
            else if (Request.Query.ContainsKey("nit"))
            {
                <div class="alert alert-warning">No se encontraron datos para el NIT proporcionado.</div>
            }
        </div>
    </div>
</div>