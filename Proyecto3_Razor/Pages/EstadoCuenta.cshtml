@page
@model Proyecto3_Razor.Pages.EstadoCuentaModel
@{
    ViewData["Title"] = "Estado de Cuenta";
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Consulta de Estado de Cuenta</h4>
            <span class="badge bg-info">IPC2 - Proyecto 3</span>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 mb-4">
                <div class="col-md-8">
                    <input type="text" name="nit" class="form-control" placeholder="Ingrese NIT del cliente (ej. 202307764)" value="@Request.Query["nit"]">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">Consultar</button>
                </div>
            </form>

            <hr />

            @if (Model.Clientes != null && Model.Clientes.Any())
            {
                foreach (var cliente in Model.Clientes)
                {
                    <div class="mb-5">
                        <div class="row">
                            <div class="col-md-6">
                                <h5><strong>Cliente:</strong> @cliente.Nombre (@cliente.NIT)</h5>
                            </div>
                            <div class="col-md-6 text-md-end">
                                <h5 class="@(cliente.SaldoActual < 0 ? "text-danger" : "text-success")">
                                    <strong>Saldo Actual:</strong> Q @cliente.SaldoActual.ToString("N2")
                                </h5>
                            </div>
                        </div>

                        <table class="table table-striped table-hover mt-3">
                            <thead class="table-secondary">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Cargo (Deuda)</th>
                                    <th>Abono (Pago)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var trans in cliente.Transacciones)
                                {
                                    <tr>
                                        <td>@trans.Fecha</td>
                                        <td class="text-danger">@trans.Cargo</td>
                                        <td class="text-success">@trans.Abono</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
            else if (Request.Query.ContainsKey("nit"))
            {
                <div class="alert alert-warning">No se encontraron datos para el NIT proporcionado.</div>
            }
        </div>
    </div>
</div>